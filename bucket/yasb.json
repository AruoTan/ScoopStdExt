{
    "version": "1.9.0",
    "description": "A highly configurable Windows status bar written in Python",
    "homepage": "https://github.com/amnweb/yasb",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/amnweb/yasb/releases/download/v1.9.0/yasb-1.9.0-x64.msi",
            "hash": "04e1c46a0a50025e91b57bf0e17aa93c4041ef23c4b8f1d2f0216113ab328675"
        },
        "arm64": {
            "url": "https://github.com/amnweb/yasb/releases/download/v1.9.0/yasb-1.9.0-aarch64.msi",
            "hash": "1fb13b4d0b115d1e773d2d15237efccd6950baa7174a92eb85d057392cce6683"
        }
    },
    "shortcuts": [
        [
            "yasb.exe",
            "YASB"
        ]
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/amnweb/yasb/releases/download/v$version/yasb-$version-x64.msi"
            },
            "arm64": {
                "url": "https://github.com/amnweb/yasb/releases/download/v$version/yasb-$version-aarch64.msi"
            }
        },
        "hash": {
            "url": "$baseurl/checksums.txt"
        }
    },
    "env_set": {
        "YASB_CONFIG_HOME": "$persist_dir"
    },
    "pre_install": [
        "$scriptsdir = \"$bucketsdir\\$bucket\\scripts\"",
        "'bg-runner.vbs' | ForEach-Object {",
        "    $content = Get-Content \"$scriptsdir\\$_\"",
        "    $content = $content.Replace('$app', 'yasb.exe')",
        "    $content | Set-Content -Path \"$dir\\$_\"",
        "}"
    ],
    "bin": [
        "yasb.exe",
        "yasbc.exe",
        "yasb_themes.exe"
    ]
}
